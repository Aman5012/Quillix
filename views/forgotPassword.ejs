<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('./partials/head') %>
    <title>Forgot Password | Quillix</title>
</head>
<body class="bg-light">
    <%- include('./partials/nav') %>
    <div class="container mt-5" style="max-width: 500px;">
        <div class="card shadow-sm border-0 rounded-4">
            <div class="card-body p-4">
                <h2 class="mb-4 fw-bold text-center">Recover Account</h2>
                
                <% if(locals.message) { %>
                    <div class="alert alert-success"><%= locals.message %></div>
                <% } %>
                <% if(locals.error) { %>
                    <div class="alert alert-danger"><%= locals.error %></div>
                <% } %>

                <form action="/user/forgot-password" method="POST">
                    <div class="mb-4">
                        <label for="email" class="form-label fw-bold">Email address</label>
                        <input type="email" class="form-control" id="email" name="email" placeholder="Enter your registered email" required>
                    </div>
                    <button type="submit" class="btn btn-primary w-100 rounded-pill flex-grow-1 shadow-sm">Request Reset Link</button>
                </form>
            </div>
        </div>
    </div>
    <%- include('./partials/scripts') %>
</body>
</html>
