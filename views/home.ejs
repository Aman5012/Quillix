<!DOCTYPE html>
<html lang="en">

<head>
    <%- include('./partials/head') %>
        <title>HomePage | Quillix</title>
</head>

<body class="bg-light">
    <%- include('./partials/nav') %>

        <!-- Hero Section -->
        <div class="p-5 mb-5 text-center bg-dark text-white shadow"
            style="background: linear-gradient(135deg, #1f1c2c 0%, #928DAB 100%);">
            <h1 class="display-4 fw-bold mb-3">Welcome to Quillix</h1>
            <p class="lead mb-4 mx-auto" style="max-width: 700px;">
                "The only limit to our realization of tomorrow will be our doubts of today." <br /><small>– Franklin D.
                    Roosevelt</small>
            </p>
            <p class="mb-4">Unleash your creativity. Share your thoughts with the world, and get inspired by others.</p>

            <% if (locals.user) { %>
                <a href="/blog/add-new" class="btn btn-primary btn-lg px-5 shadow rounded-pill">Write a Blog</a>
                <% } else { %>
                    <a href="/user/signup" class="btn btn-light btn-lg px-5 shadow rounded-pill text-dark">Join Now to
                        Write</a>
                    <% } %>
        </div>

        <!-- Blogs Grid -->
        <div class="container mb-5">
            <h2 class="mb-4 fw-bold text-center">Latest Reads</h2>
            <div class="row row-cols-1 row-cols-md-2 row-cols-lg-4 g-4">
                <% if (blogs && blogs.length> 0) { %>
                    <% blogs.forEach(blog=> { %>
                        <div class="col">
                            <div class="card h-100 shadow-sm border-0 rounded-4 overflow-hidden"
                                style="transition: transform 0.3s;">
                                <img src="<%= blog.coverImageURL %>" class="card-img-top object-fit-cover"
                                    alt="Cover Image" style="height: 200px;">
                                <div class="card-body d-flex flex-column">
                                    <h5 class="card-title fw-bold text-dark">
                                        <%= blog.title %>
                                    </h5>
                                    <p class="card-text text-muted text-truncate" style="max-height: 3rem;">
                                        <%= blog.body %>
                                    </p>
                                    <div class="mt-auto">
                                        <a href="/blog/<%= blog._id %>"
                                            class="btn btn-outline-primary w-100 stretched-link rounded-pill">Read
                                            More</a>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <% }) %>
                            <% } else { %>
                                <div class="col-12 text-center text-muted">
                                    <h5>No blogs published yet. Be the first one to share!</h5>
                                </div>
                                <% } %>
            </div>
        </div>

        <!-- Footer -->
        <footer class="bg-dark text-white text-center py-4 mt-auto">
            <div class="container">
                <p class="mb-0">&copy; <%= new Date().getFullYear() %> Quillix. All rights reserved.</p>
            </div>
        </footer>

        <%- include('./partials/scripts') %>
</body>

</html>