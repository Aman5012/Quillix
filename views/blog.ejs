<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('./partials/head') %>
    <title><%= blog.title %></title>
</head>
<body>
    <%- include('./partials/nav') %>

    <div class="container mt-4">
        <h1><%= blog.title %></h1>
        
        <div class="d-flex align-items-center mb-4 mt-3">
            <img src="<%= blog.createdBy.profileImageURL %>" class="rounded-circle object-fit-cover shadow-sm" style="width: 50px; height: 50px; margin-right: 15px;" alt="Author Profile Image" />
            <div>
                <h5 class="mb-0"><%= blog.createdBy.fullName %></h5>
                <small class="text-muted"><%= new Date(blog.createdAt).toLocaleDateString() %></small>
            </div>
        </div>

        <div class="text-center mb-4">
            <img src="<%= blog.coverImageURL %>" style="max-width: 600px; width: 100%; height: auto;" class="img-fluid rounded shadow-sm" />
        </div>
        <p class="fs-5" style="white-space: pre-wrap; line-height: 1.8;"><%= blog.body %></p>
    </div>

    <div class="container mt-3 mb-5">
        <h3 class="mb-4">Comments (<%= comments ? comments.length : 0 %>)</h3>
        
        <% if (locals.user) { %>
            <form action="/blog/comment/<%= blog._id %>" method="POST" class="mb-4 bg-light p-4 rounded shadow-sm">
                <div class="mb-3">
                    <label for="content" class="form-label">Leave a comment</label>
                    <textarea class="form-control mb-2" name="content" id="content" rows="3" placeholder="What are your thoughts?" required></textarea>
                </div>
                <button type="submit" class="btn btn-primary shadow-sm">Submit</button>
            </form>
        <% } %>

        <div class="mt-4">
            <% if (comments) { comments.forEach(comment => { %>
                <div class="card mb-3 shadow-sm border-0 bg-light">
                    <div class="card-body">
                        <div class="d-flex align-items-center mb-2">
                            <img src="<%= comment.createdBy.profileImageURL %>" class="rounded-circle object-fit-cover shadow-sm" style="width: 40px; height: 40px; margin-right: 10px;" alt="User Profile Image">
                            <div>
                                <h6 class="mb-0"><%= comment.createdBy.fullName %></h6>
                                <small class="text-muted" style="font-size: 0.8rem;"><%= new Date(comment.createdAt).toLocaleDateString() %></small>
                            </div>
                        </div>
                        <p class="card-text mb-0 mt-2"><%= comment.content %></p>
                    </div>
                </div>
            <% }) } %>
        </div>
    </div>

    <%- include('./partials/scripts') %>
</body>
</html>
