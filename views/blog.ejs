<!DOCTYPE html>
<html lang="en">

<head>
    <%- include('./partials/head') %>
        <title>
            <%= blog.title %>
        </title>
        <style>
            .blog-content img {
                max-width: 100%;
                height: auto;
                border-radius: 8px;
                margin: 1px 0;
            }

            .blog-content pre {
                background-color: #23241f;
                color: #f8f8f2;
                padding: 1rem;
                border-radius: 8px;
                overflow-x: auto;
                margin: 1rem 0;
                box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
                font-size: 0.9rem;
            }

            .blog-content code {
                background-color: #a3a7ac;
                padding: 0.2rem 0.4rem;
                border-radius: 4px;
                color: #d63384;
                font-family: monospace;
            }

            .blog-content pre code {
                background-color: transparent;
                padding: 0;
                color: inherit;
            }

            .blog-content h1,
            .blog-content h2,
            .blog-content h3 {
                margin-top: 1.25rem;
                margin-bottom: 0.5rem;
                font-weight: 700;
                color: #212529;
            }

            .blog-content blockquote {
                border-left: 5px solid #0d6efd;
                padding-left: 1rem;
                margin: 1rem 0;
                color: #6c757d;
                font-style: italic;
                background: #939496;
                padding: 0.75rem 1rem;
                border-radius: 0 8px 8px 0;
            }
        </style>
</head>
<!-- To change the ENTIRE page background color, edit this class or style below -->
<body style="background-color: #f2f4f7;"> 
    <%- include('./partials/nav') %>

        <div class="container mt-4">
            <h1>
                <%= blog.title %>
            </h1>

            <div class="d-flex align-items-center mb-4 mt-3">
                <img src="<%= blog.createdBy.profileImageURL %>" class="rounded-circle object-fit-cover shadow-sm"
                    style="width: 50px; height: 50px; margin-right: 15px;" alt="Author Profile Image" />
                <div>
                    <h5 class="mb-0">
                        <%= blog.createdBy.fullName %>
                    </h5>
                    <small class="text-muted">
                        <%= new Date(blog.createdAt).toLocaleDateString() %>
                    </small>
                </div>
            </div>

            <div class="text-center mb-4">
                <img src="<%= blog.coverImageURL %>" style="max-width: 600px; width: 100%; height: auto;"
                    class="img-fluid rounded shadow-sm" />
            </div>

            <!-- Render parsed HTML coming from Quill -->
            <div class="blog-content mt-3" style="line-height: 1.6; font-size: 1rem; color: #333;">
                <%- blog.body %>
            </div>
        </div>

        <div class="container mt-3 mb-5">
            <h3 class="mb-4">Comments (<%= comments ? comments.length : 0 %>)</h3>

            <% if (locals.user) { %>
                <form action="/blog/comment/<%= blog._id %>" method="POST" class="mb-4 bg-light p-4 rounded shadow-sm">
                    <div class="mb-3">
                        <label for="content" class="form-label">Leave a comment</label>
                        <textarea class="form-control mb-2" name="content" id="content" rows="3"
                            placeholder="What are your thoughts?" required></textarea>
                    </div>
                    <button type="submit" class="btn btn-primary shadow-sm">Submit</button>
                </form>
                <% } %>

                    <div class="mt-4">
                        <% if (comments) { comments.forEach(comment=> { %>
                            <div class="card mb-3 shadow-sm border-0 bg-light">
                                <div class="card-body">
                                    <div class="d-flex align-items-center mb-2">
                                        <img src="<%= comment.createdBy.profileImageURL %>"
                                            class="rounded-circle object-fit-cover shadow-sm"
                                            style="width: 40px; height: 40px; margin-right: 10px;"
                                            alt="User Profile Image">
                                        <div>
                                            <h6 class="mb-0">
                                                <%= comment.createdBy.fullName %>
                                            </h6>
                                            <small class="text-muted" style="font-size: 0.8rem;">
                                                <%= new Date(comment.createdAt).toLocaleDateString() %>
                                            </small>
                                        </div>
                                    </div>
                                    <p class="card-text mb-0 mt-2">
                                        <%= comment.content %>
                                    </p>
                                </div>
                            </div>
                            <% }) } %>
                    </div>
        </div>

        <%- include('./partials/scripts') %>
</body>

</html>