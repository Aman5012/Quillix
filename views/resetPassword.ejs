<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('./partials/head') %>
    <title>Set New Password | Quillix</title>
</head>
<body class="bg-light">
    <%- include('./partials/nav') %>
    <div class="container mt-5" style="max-width: 500px;">
        <div class="card shadow-sm border-0 rounded-4">
            <div class="card-body p-4">
                <h2 class="mb-4 fw-bold text-center">Set New Password</h2>
                
                <% if(locals.error) { %>
                    <div class="alert alert-danger"><%= locals.error %></div>
                <% } %>

                <form action="/user/reset-password/<%= token %>" method="POST">
                    <div class="mb-4">
                        <label for="password" class="form-label fw-bold">New Password</label>
                        <input type="password" class="form-control" id="password" name="password" placeholder="Enter a secure new password" required>
                    </div>
                    <button type="submit" class="btn btn-primary w-100 rounded-pill shadow-sm">Update Password</button>
                </form>
            </div>
        </div>
    </div>
    <%- include('./partials/scripts') %>
</body>
</html>
